#!/bin/bash
USERNAME=$(whoami)
HOSTNAME=$(hostname)
DATE_TIME=$(date)
OS=$(uname -s)
CURRENT_DIR=$(pwd)
HOME_DIR=$HOME
USERS_ONLINE=$(who | wc -l)
UPTIME=$(uptime -p)
echo "=============================="
echo "SYSTEM INFORMATION"
echo "=============================="
echo "Username: $USERNAME"
echo "Hostname: $HOSTNAME"
echo "Date & Time: $DATE_TIME"
echo "OS: $OS"
echo "Current Dir: $CURRENT_DIR"
echo "Home Dir: $HOME_DIR"
echo "Users Online: $USERS_ONLINE"
echo "Uptime: $UPTIME"
